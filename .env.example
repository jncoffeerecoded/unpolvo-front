# Copia este fichero a `.env` y rellena los valores.

# Desarrollo (SQLite):
DATABASE_URL="file:./dev.db"

# Producción (PostgreSQL) — cambia también `provider` en prisma/schema.prisma:
# DATABASE_URL="postgresql://tuprepa:tuprepa@localhost:5432/tuprepa?schema=public"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Verificación de identidad (KYC) — proveedor externo, sin almacenar biometría:
STRIPE_SECRET_KEY=""
STRIPE_IDENTITY_WEBHOOK_SECRET=""

# Autenticación (Auth.js / NextAuth v5)
AUTH_SECRET="genera-uno-con: npx auth secret"
AUTH_TRUST_HOST="true"

# Almacenamiento de fotos (Railway / S3-compatible). Vacío en dev → /public/uploads
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
